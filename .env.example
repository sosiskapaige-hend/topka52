BOT_TOKEN=your_telegram_bot_token_here
WALLET_ADDRESS=0x...
WEBAPP_URL=https://your-domain.example/app/index.html

# Xrocket Pay
# Получите API ключ: откройте @xRocket в Telegram → xRocket Pay → Create App → скопируйте токен
XROCKET_API_URL=https://pay.api.xrocket.exchange/
XROCKET_API_KEY=e46a793883a7c55a816d557d1
XROCKET_CURRENCY=USDT

# Webhook: настройте URL в карточке приложения @xRocket → ваше приложение → Webhook URL
# Формат: https://your-domain.example/api/xrocket/webhook
# Подпись: HMAC-SHA256(body, SHA256(api_token)) — проверяется автоматически
# XROCKET_WEBHOOK_SECRET=  # оставьте пустым — ключ подписи вычисляется из XROCKET_API_KEY

# Polling (резервный способ, если webhook недоступен)
ENABLE_XROCKET_POLL=true
XROCKET_POLL_INTERVAL=60
