DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# Xrocket Pay
# Получите API ключ: @xRocket → xRocket Pay → Create App → скопируйте токен
XROCKET_API_URL=https://pay.xrocket.tg/
XROCKET_API_KEY=a93c2804b3176b8175e8fd7f8
XROCKET_CURRENCY=USDT

# Webhook URL в карточке приложения @xRocket:
# https://topka52.onrender.com/xrocket/webhook
# XROCKET_WEBHOOK_SECRET=  # оставьте пустым — ключ вычисляется из XROCKET_API_KEY

# Polling (резервный способ)
ENABLE_XROCKET_POLL=true
XROCKET_POLL_INTERVAL=60

# Render автоматически задаёт PORT — не указывайте вручную
